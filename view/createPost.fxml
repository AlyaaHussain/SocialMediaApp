<VBox spacing="10"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.PostController"
      stylesheets="@../style.css"
      styleClass="card">

    <Label text="Create Post"/>

    <TextArea fx:id="contentField"
              promptText="What's on your mind?"
              prefHeight="120"/>

    <Button text="Post"
            styleClass="button-main"
            onAction="#createPost"/>

</VBox>