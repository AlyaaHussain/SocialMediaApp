<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" 
            fx:controller="controller.HomeController" prefWidth="1000.0" prefHeight="750.0" 
            style="-fx-background-color: #121212;">
    <stylesheets><URL value="@styles.css" /></stylesheets>
    
    <top>
        <HBox spacing="25" alignment="CENTER_LEFT" prefHeight="65" 
              style="-fx-background-color: #1DA1F2; -fx-padding: 0 30 0 30; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 5);">
            <Label text="SocialApp" style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';"/>
            <Region HBox.hgrow="ALWAYS" />
            
            <HBox spacing="15" alignment="CENTER">
                <Button text="🏠 Home" styleClass="nav-btn-active"/>
                <Button text="👥 Friends" onAction="#goToFriends" styleClass="nav-btn"/>
                <Button text="🔔 Notifications" onAction="#goToNotifications" styleClass="nav-btn"/>
                <Separator orientation="VERTICAL" prefHeight="20" style="-fx-opacity: 0.3;"/>
                <Button text="Logout" onAction="#handleLogout" 
                        style="-fx-background-color: #ff4757; -fx-text-fill: white; -fx-background-radius: 15; -fx-cursor: hand;"/>
            </HBox>
        </HBox>
    </top>

    <left>
        <VBox spacing="15" prefWidth="240" styleClass="sidebar">
            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
            
            <VBox alignment="CENTER" spacing="10" styleClass="profile-preview-card">
                <Label fx:id="userNameLabel" text="User Name" 
                       style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                <Button text="View My Profile" onAction="#goToProfile" maxWidth="Infinity" styleClass="btn-secondary-outline" />
            </VBox>
            
            <Separator prefWidth="200" style="-fx-opacity: 0.1;" />
            
            <Label text="Quick Links" style="-fx-text-fill: #888; -fx-font-size: 12px; -fx-font-weight: bold;"/>
            <Button text="Explore Trends" maxWidth="Infinity" styleClass="btn-sidebar-link" />
            <Button text="Saved Posts" maxWidth="Infinity" styleClass="btn-sidebar-link" />
        </VBox>
    </left>
    
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: #121212; -fx-border-color: transparent;">
            <VBox fx:id="feedContainer" spacing="25" alignment="TOP_CENTER">
                <padding><Insets top="20" bottom="30"/></padding>
                
                <VBox spacing="12" maxWidth="600" styleClass="create-post-card">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="Share something..." style="-fx-text-fill: #aaa; -fx-font-size: 14px;"/>
                    </HBox>
                    <TextArea fx:id="postContentArea" promptText="What's happening?" 
                              prefRowCount="3" wrapText="true" styleClass="modern-textarea"/>
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <ChoiceBox fx:id="privacyChoiceBox" styleClass="choice-box-modern" />
                        <Button text="📷 Image" onAction="#handleAddImage" styleClass="btn-icon" />
                        <Label fx:id="imageStatusLabel" textFill="#33C100" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button text="Post" onAction="#handleCreatePost" prefWidth="100" styleClass="btn-primary-rounded" />
                    </HBox>
                </VBox>
                
                <VBox fx:id="postsVBox" spacing="20" maxWidth="600" />
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>