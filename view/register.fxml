<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import java.net.URL?>

<StackPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="controller.RegisterController" prefWidth="800.0" prefHeight="600.0">
    <stylesheets>
        <URL value="@styles.css" />
    </stylesheets>

    <VBox alignment="CENTER" maxWidth="400.0" maxHeight="500.0" spacing="15.0" styleClass="auth-card">
        <Label text="Create Account" styleClass="title-text" />
        <Label text="Join our community today" textFill="#A0A0A0" />

        <Label fx:id="errorLabel" styleClass="error-text" visible="false" />

        <TextField fx:id="nameField" promptText="Full Name" styleClass="text-field" />
        <TextField fx:id="emailField" promptText="Email Address" styleClass="text-field" />
        <PasswordField fx:id="passwordField" promptText="Password" styleClass="password-field" />

        <Button text="Sign Up" onAction="#handleRegister" maxWidth="Infinity" styleClass="btn-primary" />

        <HBox alignment="CENTER" spacing="5">
            <Label text="Already have an account?" textFill="#A0A0A0" />
            <Label text="Login Here" onMouseClicked="#goToLogin" styleClass="link-text" />
        </HBox>
    </VBox>
</StackPane>